# Copy this file to openclaw/acquire_a1.env or /etc/openclaw/acquire_a1.env
# and fill in the values for your tenancy.

# OCI CLI settings
OCI_REGION="il-jerusalem-1"
# Optional if you do not use the default OCI CLI profile/config path.
# OCI_CLI_PROFILE="DEFAULT"
# OCI_CLI_CONFIG_FILE="/home/opc/.oci/config"

# Launch target
COMPARTMENT_OCID="ocid1.compartment.oc1..replace_me"
SUBNET_OCID="ocid1.subnet.oc1..replace_me"
SSH_PUBLIC_KEY_PATH="/home/opc/.ssh/id_ed25519.pub"
INSTANCE_DISPLAY_NAME="openclaw-a1"

# Telegram notifications
TELEGRAM_BOT_TOKEN="replace_me"
TELEGRAM_CHAT_ID="replace_me"

# Optional launch overrides
TARGET_SHAPE="VM.Standard.A1.Flex"
TARGET_OCPUS="4"
TARGET_MEMORY_GB="24"
IMAGE_OS="Canonical Ubuntu"
IMAGE_OS_VERSION="24.04"
ASSIGN_PUBLIC_IP="false"
SLEEP_SECONDS="60"
MAX_JITTER_SECONDS="20"
TELEGRAM_NOTIFY_TERMINAL_ERRORS="true"
INSTANCE_LAUNCH_TIMEOUT_SECONDS="900"

# Optional image and metadata overrides
# IMAGE_OCID="ocid1.image.oc1..replace_me"
# USER_DATA_FILE="/home/opc/openclaw/cloud-init.yaml"
# METADATA_JSON_FILE="/home/opc/openclaw/metadata.json"

# Optional if capacity report needs the tenancy/root compartment OCID.
# CAPACITY_REPORT_COMPARTMENT_OCID="ocid1.tenancy.oc1..replace_me"

# Optional test hooks for local mocking.
# OCI_BIN="/usr/local/bin/oci"
# JQ_BIN="/usr/bin/jq"
# CURL_BIN="/usr/bin/curl"
